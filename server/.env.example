# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/rentify
# Or use Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rentify

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_EXPIRE=7d

# ─── Admin Credentials (env-based login) ──────────────────────────────────────
ADMIN_EMAIL=admin@rentify.app
ADMIN_PASSWORD=Admin@1234

# ─── Cloudinary (property images + landlord avatars) ─────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SMTP (OTP emails) ───────────────────────────────────────────────────────
SMTP_EMAIL=your_smtp_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
# Gmail: enable 2FA → generate App Password → use here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Leave blank to allow all origins in dev:
ALLOWED_ORIGINS=
