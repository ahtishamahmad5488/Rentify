# ─── Rentify Mobile Client (.env) ────────────────────────────────────────────
# Copy to .env and fill in real values before running.

# Backend server URL (no trailing slash)
API_URL=http://10.0.2.2:5000/api
# Android emulator uses 10.0.2.2 for localhost.
# For a real device on the same WiFi, use your machine's LAN IP:
# API_URL=http://192.168.x.x:5000/api

# Google Maps API key (Android)
# - Enable "Maps SDK for Android" in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
